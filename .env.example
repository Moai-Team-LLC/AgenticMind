# AgenticMind — environment template
#
# Copy to `.env.local` and fill in real values:  cp .env.example .env.local
# `.gitignore` excludes `.env*`, so secrets never get committed.
#
# Local dev needs only Postgres (pgvector) + an OpenRouter key:
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
#   bun run db:migrate-local && bun run dev

# ─── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
SKIP_VALIDATION=true

# ─── Database (Postgres + pgvector) ───────────────────────────────────
# docker-compose.local.yml maps the db to host port 5435.
DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5435/postgres
DATABASE_POOL_MAX=10
# Off for local (the docker Postgres has no TLS). Set true for managed
# Postgres (Supabase, RDS, …) that requires SSL.
DATABASE_SSL=false

# ─── Chat / synthesis LLM (OpenRouter by default) ─────────────────────
# https://openrouter.ai/ — used for synthesis, classification, extraction.
# (Embeddings no longer need this — see the Embeddings block below.)
OPENROUTER_API_KEY=<your-openrouter-key>
# To use a local/OpenAI-compatible chat model instead (e.g. Ollama → fully
# offline together with the local embeddings default), set:
#   CHAT_PROVIDER=openai
#   CHAT_BASE_URL=http://localhost:11434/v1
#   CHAT_API_KEY=
#   CHAT_MODEL_SIMPLE=llama3.2     # cheap/fast tier
#   CHAT_MODEL_COMPLEX=llama3.1    # flagship tier
# Optional cross-encoder rerank (off by default; needs OPENROUTER_API_KEY):
#   RERANK_ENABLED=true

# ─── Embeddings (Agentic Product Standard — multi-provider) ───────────
# Default: a zero-key, offline, in-process MULTILINGUAL model (no API key,
# no network) — this is what makes a clean clone work without any cloud key.
#   EMBED_PROVIDER=local
#   EMBED_MODEL=Xenova/bge-m3      # 1024-dim multilingual; first run downloads it
#   EMBED_POOLING=cls              # bge-m3 → cls, e5 family → mean
#
# To use a hosted OpenAI-compatible endpoint instead (OpenAI, Ollama, vLLM,
# OpenRouter, …), set EMBED_PROVIDER=openai + EMBED_BASE_URL (+ key). The model
# MUST output the schema dimension (1024) or ingestion fails fast.
#   EMBED_PROVIDER=openai
#   EMBED_BASE_URL=http://localhost:11434/v1   # e.g. Ollama
#   EMBED_MODEL=bge-m3
#   EMBED_API_KEY=

# ─── Observability (OpenTelemetry, optional) ──────────────────────────
# The knowledge pipeline emits OpenInference spans (the replayable why-trace).
# Set an OTLP/HTTP endpoint to export them to Phoenix / Langfuse / LangSmith /
# any OTLP backend. Unset → tracing is a zero-cost no-op.
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Auth (MCP bearer tokens) ─────────────────────────────────────────
# HS256 secret that signs/verifies the typ="mcp" JWTs agents present to
# /api/mcp. Generate a long random string.
AUTH_SECRET=<random-32+char-secret>

# ─── Knowledge tier flags ─────────────────────────────────────────────
# Tier 0 (chunks) is always on. These gate the higher tiers.
KNOWLEDGE_CARDS_ENABLED=true
KNOWLEDGE_CACHE_ENABLED=true
KNOWLEDGE_GRAPHRAG_ENABLED=false

# ─── MCP host public URL ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Blob storage for ingested materials (optional) ───────────────────
# S3-compatible (e.g. DigitalOcean Spaces). Leave unset to use the no-op
# store: material rows are still created, raw bytes just aren't retained.
# SPACES_REGION=
# SPACES_ACCESS_KEY=
# SPACES_SECRET_KEY=
# SPACES_KNOWLEDGE_BUCKET=
