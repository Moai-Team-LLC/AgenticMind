# AgenticMind deploy — copy to deploy/.env (or run ./gen-secrets.sh, which
# generates the two secrets for you). docker compose reads this file automatically.

# Postgres password. Any strong random value; the db and the server share it.
# Auto-generated by ./gen-secrets.sh.
AGENTICMIND_DB_PASSWORD=

# Static MCP bearer your app sends as `Authorization: Bearer <key>`. One shared
# key — no token minting. Use a long random value (>=24 chars).
# Auto-generated by ./gen-secrets.sh.
MCP_API_KEY=

# Your existing OpenAI key — AgenticMind reuses it for synthesis (no OpenRouter).
OPENAI_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────
# AGENTICMIND_TAG=latest                 # image tag to pull (default: latest)
# AGENTICMIND_PORT=3000                  # host port for the MCP server
# AGENTICMIND_CHAT_MODEL_SIMPLE=gpt-4o-mini
# AGENTICMIND_CHAT_MODEL_COMPLEX=gpt-4o
