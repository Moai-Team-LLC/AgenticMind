# npm installs the (bun-canonical) workspace with lenient peer resolution.
# A few fast-moving deps over-pin peer versions that bun/pnpm tolerate but npm 7+
# rejects (e.g. mcp-handler pins @modelcontextprotocol/sdk to an exact older
# minor). bun.lock stays the canonical, reproducible lockfile — npm is a
# supported convenience path for self-hosters who already have Node. See README.
legacy-peer-deps=true
