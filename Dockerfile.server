# glibc base (NOT alpine): onnxruntime-node — the local-embeddings native addon
# behind transformers.js — ships glibc binaries and fails to load on musl/alpine
# ("__getauxval: symbol not found"). Debian-based bun keeps the default zero-key
# embedder working out of the box.
FROM oven/bun:1.3.11 AS base
ENV NODE_ENV=production
WORKDIR /app

FROM base AS builder
COPY . .
RUN bunx --bun turbo@2.9.6 prune @agenticmind/server --docker

FROM base AS installer
COPY --from=builder /app/out/json/ .
RUN bun install --frozen-lockfile
COPY --from=builder /app/out/full/ .
# Drizzle migrations (applied on deploy)
COPY drizzle.config.ts ./drizzle.config.ts
COPY drizzle/ ./drizzle/

FROM base AS runner
# Run unprivileged. Numeric uid/gid is portable across base images (no
# adduser/useradd dependency).
COPY --from=installer --chown=1001:1001 /app ./
USER 1001:1001

# Required environment variables:
# DATABASE_URL       — Postgres (pgvector + pgvectorscale)
# AUTH_SECRET        — signs/verifies MCP bearer tokens
# CHAT_API_KEY       — chat/synthesis LLM (OpenAI-compatible; CHAT_BASE_URL to override)
# S3_*               — optional S3-compatible blob storage for ingested materials

ARG PORT
ENV PORT=${PORT:-3000}
EXPOSE ${PORT}

WORKDIR /app/apps/server
# Run the server directly under Bun (native TS; resolves @/ via tsconfig paths).
CMD ["bun", "--bun", "src/index.ts"]
