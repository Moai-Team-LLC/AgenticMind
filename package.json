{
  "name": "agenticmind",
  "version": "0.4.1",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "dev": "turbo run dev --framework-inference=false",
    "start-dev": "turbo run start-dev --framework-inference=false",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "tsc": "turbo run tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "dotenvx run -f .env.local -- tsx scripts/eval.ts",
    "build-eval": "tsx scripts/build-eval-cases.ts",
    "seed-eval": "dotenvx run -f .env.local -- tsx scripts/seed-eval-corpus.ts",
    "reembed": "dotenvx run -f .env.local -- tsx scripts/reembed.ts",
    "calibrate": "dotenvx run -f .env.local -- tsx scripts/calibrate.ts",
    "ingest": "dotenvx run -f .env.local -- tsx scripts/ingest.ts",
    "issue-token": "dotenvx run -f .env.local -- tsx scripts/issue-mcp-token.ts",
    "check": "turbo run format lint tsc && vitest run",
    "db:generate": "dotenvx run -f .env.local -- drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-local": "dotenvx run -f .env.local -- drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push-local": "dotenvx run -f .env.local -- drizzle-kit push",
    "db:introspect": "drizzle-kit introspect",
    "db:introspect-local": "dotenvx run -f .env.local -- drizzle-kit introspect"
  },
  "dependencies": {
    "drizzle-kit": "0.31.10",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@agenticmind/oxlint-config": "*",
    "@agenticmind/shared": "*",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@dotenvx/dotenvx": "^1.67.0",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "better-sqlite3",
    "esbuild",
    "msgpackr-extract",
    "msw",
    "sharp",
    "unrs-resolver"
  ],
  "packageManager": "bun@1.3.11"
}
