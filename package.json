{
  "name": "agenticmind",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --framework-inference=false",
    "start-dev": "turbo run start-dev --framework-inference=false",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "tsc": "turbo run tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "dotenvx run -f .env.local -- bun scripts/eval.ts",
    "seed-eval": "dotenvx run -f .env.local -- bun scripts/seed-eval-corpus.ts",
    "reembed": "dotenvx run -f .env.local -- bun scripts/reembed.ts",
    "calibrate": "dotenvx run -f .env.local -- bun scripts/calibrate.ts",
    "ingest": "dotenvx run -f .env.local -- bun scripts/ingest.ts",
    "check": "turbo run format lint tsc && bun test",
    "db:generate": "dotenvx run -f .env.local -- drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-local": "dotenvx run -f .env.local -- drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push-local": "dotenvx run -f .env.local -- drizzle-kit push",
    "db:introspect": "drizzle-kit introspect",
    "db:introspect-local": "dotenvx run -f .env.local -- drizzle-kit introspect"
  },
  "dependencies": {
    "drizzle-kit": "0.31.10"
  },
  "devDependencies": {
    "@agenticmind/oxlint-config": "workspace:*",
    "@agenticmind/shared": "workspace:*",
    "@dotenvx/dotenvx": "^1.67.0",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "better-sqlite3",
    "esbuild",
    "msgpackr-extract",
    "msw",
    "sharp",
    "unrs-resolver"
  ]
}
